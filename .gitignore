# Build outputs
**/bin/
**/obj/
**/dist/
**/out/

# Dependency folders
**/node_modules/
**/.angular/

# System and editor files
.idea/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates

# Database & local files
*.db
*.db-shm
*.db-wal
*.log
wwwroot/uploads/*
!wwwroot/uploads/.gitkeep
!wwwroot/uploads/apks/
wwwroot/uploads/apks/*
!wwwroot/uploads/apks/.gitkeep

# Uploaded binaries live under backend/ too — patterns with a slash are
# anchored to this file's dir, so the rules above didn't catch these.
backend/wwwroot/uploads/**/*.apk
backend/wwwroot/uploads/apps/
backend/wwwroot/uploads/other/
backend/wwwroot/uploads/product/
backend/wwwroot/uploads/logo/

# ================================================
# SECRETS — NEVER COMMIT THESE
# ================================================
# Real .env file with credentials
.env

# ASP.NET Core appsettings with real credentials
**/appsettings.json
**/appsettings.Development.json
**/appsettings.Production.json

# Keep the example/template files (no real secrets)
!**/appsettings.example.json
!.env.example
