# =============================================================
# ZW Ecosystem — Server Environment Variables
# =============================================================
# IMPORTANT: This file MUST NEVER be committed to Git.
# It is listed in .gitignore.
# Copy this file to .env on the server and fill real values.
# =============================================================

# --- Database ---
POSTGRES_DB=zwecodb
POSTGRES_USER=zw_user
POSTGRES_PASSWORD=YOUR_STRONG_DB_PASSWORD_HERE

# --- Backend App (ASP.NET Core reads these) ---
DB_CONNECTION_STRING=Host=zwecosystem-postgres;Port=5432;Database=zwecodb;Username=zw_user;Password=YOUR_STRONG_DB_PASSWORD_HERE;Include Error Detail=true;

# --- JWT ---
JWT_SECRET=YOUR_MINIMUM_32_CHARACTER_JWT_SECRET_HERE_CHANGE_THIS

# --- SMTP (Optional - for email OTP etc.) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
SMTP_FROM=noreply@zwecosystem.com
